# ---------------------------------------------------------------------------
# Gemini (Google AI)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# ElevenLabs TTS
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ---------------------------------------------------------------------------
# Slack
# ---------------------------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_APPROVAL_CHANNEL_ID=

# ---------------------------------------------------------------------------
# Microsoft SharePoint
# ---------------------------------------------------------------------------
# Site ID — get it by opening your browser console on the SharePoint site and running:
#   fetch("/_api/site/id").then(r=>r.json()).then(d=>console.log(d.value))
# Or from Graph API: GET https://graph.microsoft.com/v1.0/sites/{hostname}:/sites/{siteName}
SHAREPOINT_SITE_ID=

# Site URL — base URL of your SharePoint site (no trailing slash)
# e.g. https://foresightanalytics.sharepoint.com/sites/foresightanalytics
SHAREPOINT_SITE_URL=https://foresightanalytics.sharepoint.com/sites/foresightanalytics

# Site name — the part after /sites/ in the URL
SHAREPOINT_SITE_NAME=foresightanalytics

# Item ID of the output parent folder (e.g. YieldReport-Podcast folder)
# Get it: navigate to the folder in SharePoint → click ... → Details → ID
SHAREPOINT_OUTPUT_FOLDER_ID=

# Relative path of the output folder within the document library (for Slack link)
# e.g. Projects/Melvin's folder/YieldReport-Podcast
SHAREPOINT_OUTPUT_FOLDER_PATH=Projects/Melvin's folder/YieldReport-Podcast

# ---------------------------------------------------------------------------
# Audio assets (n8n server filesystem paths)
# ---------------------------------------------------------------------------
INTRO_AUDIO_PATH=/assets/intro.mp3
OUTRO_AUDIO_PATH=/assets/outro.mp3
