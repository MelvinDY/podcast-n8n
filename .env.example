# ---------------------------------------------------------------------------
# Gemini (Google AI)
# ---------------------------------------------------------------------------
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# ElevenLabs TTS
# ---------------------------------------------------------------------------
# Get from: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=

# Voice ID — audition candidates: Brian, Daniel, George, Charlotte
# Find IDs at: https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=

# ---------------------------------------------------------------------------
# Slack
# ---------------------------------------------------------------------------
# Bot OAuth Token (starts with xoxb-) — from Slack App settings
SLACK_BOT_TOKEN=

# Channel ID where approval requests and completion notices are posted
# Right-click channel in Slack → Copy link → extract ID from URL
SLACK_APPROVAL_CHANNEL_ID=

# ---------------------------------------------------------------------------
# Google Drive
# ---------------------------------------------------------------------------
# Parent folder ID for all episode output
# Open the Drive folder → copy ID from URL: drive.google.com/drive/folders/THIS_PART
OUTPUT_DRIVE_FOLDER_ID=

# ---------------------------------------------------------------------------
# Audio assets (n8n server filesystem paths)
# ---------------------------------------------------------------------------
# ~10-second intro clip: "This is the YieldReport daily brief."
# Encoded as MP3, 44.1kHz, 128kbps to match ElevenLabs output
INTRO_AUDIO_PATH=/assets/intro.mp3

# ~10-second outro clip: "That's the YieldReport brief. Visit yieldreport.com.au."
# Same encoding specs as intro
OUTRO_AUDIO_PATH=/assets/outro.mp3
